datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Merchant {
  id            String          @id @default(uuid())
  apiKey        String          @unique
  businessName  String
  email         String?
  receiveAddress String?        // merchant's own EVM wallet — payments settle here directly (non-custodial)
  webhookUrl    String?
  webhookSecret String?         // HMAC-SHA256 signing secret for payment webhooks
  minChargeAmount Float?        // per-transaction limits (in the charge currency); null = no limit
  maxChargeAmount Float?
  sanctionsFlagged Boolean      @default(false)  // set by the periodic re-screen if receiveAddress becomes sanctioned
  sanctionsCheckedAt DateTime?  // last time the payout wallet was re-screened
  createdAt     DateTime        @default(now())
  intents       PaymentIntent[]
}

model PaymentIntent {
  id                   String   @id @default(uuid())
  merchantId           String
  merchant             Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  amount               Float
  currency             String
  status               String   @default("PENDING")
  description          String?  // line item / memo shown on checkout + receipt
  customerEmail        String?  // optional, for invoices + emailed receipts
  reference            String?  // merchant's invoice / order number
  source               String   @default("api") // api | pos | invoice
  selectedChain        String?
  cryptoAmountRequired String?
  depositAddress       String?
  liveMarketRate       String?
  txHash               String?
  watchFromBlock       Int?     // chain height when the pay address was issued — the watcher scans from here
  confirmedAt          DateTime?
  expiresAt            DateTime
  createdAt            DateTime @default(now())
}

model User {
  id          String       @id @default(uuid())
  username    String       @unique
  email       String       @unique
  createdAt   DateTime     @default(now())
  wallets     Wallet[]
  connections Connection[] @relation("UserConnections")
  linkedFrom  Connection[] @relation("LinkedToUser")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chain     String
  address   String
  createdAt DateTime @default(now())

  @@unique([userId, chain])
}

model Connection {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation("UserConnections", fields: [userId], references: [id], onDelete: Cascade)
  linkedUserId String
  linkedUser   User     @relation("LinkedToUser", fields: [linkedUserId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([userId, linkedUserId])
}

model Configuration {
  id        String   @id @default("global_settings")
  feeRate   Float    @default(0.01) // 1% default fee
  updatedAt DateTime @updatedAt
}

model FxQuote {
  id                         String                  @id @default(uuid())
  sourceCurrency             String
  targetCurrency             String
  notional                   Float
  side                       String                  @default("sell")
  referenceRate              Float
  allInRate                  Float
  spreadBps                  Int
  feeBps                     Int
  quoteTtlSeconds            Int
  expiresAt                  DateTime
  estimatedSettlementMinutes Int
  routeId                    String
  routeProvider              String
  routeRail                  String
  sourceAmount               Float
  targetAmount               Float
  status                     String                  @default("QUOTED")
  riskChecks                 String
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  settlementInstructions     SettlementInstruction[]
  ledgerEntries              TreasuryLedgerEntry[]

  @@index([status, expiresAt])
  @@index([sourceCurrency, targetCurrency])
}

model SettlementInstruction {
  id             String                @id @default(uuid())
  quoteId        String
  quote          FxQuote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  reserveId      String                @unique
  status         String                @default("RESERVED_PENDING_COMPLIANCE")
  routeId        String
  provider       String
  rail           String
  sourceAmount   Float
  sourceCurrency String
  targetAmount   Float
  targetCurrency String
  releaseGates   String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  ledgerEntries  TreasuryLedgerEntry[]

  @@index([quoteId])
  @@index([status])
}

model TreasuryLedgerEntry {
  id            String                 @id @default(uuid())
  quoteId       String?
  quote         FxQuote?               @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  instructionId String?
  instruction   SettlementInstruction? @relation(fields: [instructionId], references: [id], onDelete: SetNull)
  account       String
  currency      String
  direction     String
  amount        Float
  memo          String
  createdAt     DateTime               @default(now())

  @@index([quoteId])
  @@index([instructionId])
  @@index([account, currency])
}

model SwapQuote {
  id                    String               @id @default(uuid())
  status                String               @default("QUOTED")
  provider              String
  fromAsset             String
  toAsset               String
  amount                String
  userAddress           String
  estimatedOutputAmount String
  platformFeeBps        Int
  platformFeeAmount     String
  priceImpactPct        Float
  priceImpactLimitPct   Float
  providerMode          String               @default("simulation")
  providerQuoteId       String?
  providerLatencyMs     Int                  @default(0)
  providerDiagnostics   String               @default("[]")
  quoteTtlSeconds       Int
  expiresAt             DateTime
  requestPayload        String
  executionStates       String
  guardrails            String
  currentState          String               @default("SOURCING")
  walletType            String?
  walletAddress         String?
  signatureKind         String?
  signatureHash         String?
  signedMessageHash     String?
  authorizationMetadata String               @default("{}")
  authorizedAt          DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  events                SwapExecutionEvent[]
  complianceReviews     ComplianceReview[]
  partnerId             String?
  partner               ApiPartner?          @relation(fields: [partnerId], references: [id])
  partnerFeeBps         Int                  @default(0)
  partnerEarnedUsd      Float                @default(0)
  partnerPaidAt         DateTime?
  // Payout is gated on VERIFIED on-chain settlement, never the self-reported swap
  // status (which any caller can drive to COMPLETE). onchainVerifiedAt is stamped
  // only after LI.FI confirms the swap settled (status DONE); settlementTxHash is
  // unique so one on-chain tx can never be claimed by two swaps. partnerPayoutId
  // claims a swap to a payout run BEFORE the transfer is sent (idempotency).
  onchainVerifiedAt     DateTime?
  settlementTxHash      String?              @unique
  partnerPayoutId       String?

  @@index([status, expiresAt])
  @@index([fromAsset, toAsset])
  @@index([partnerId])
  @@index([partnerPayoutId])
}

// Partner Swap API (Swaps-as-a-Service): external developers embed Atomic swaps
// with an API key. The plaintext key is NEVER stored — only its sha256 hash and a
// short prefix (for identification in dashboards/logs).
model ApiPartner {
  id            String          @id @default(uuid())
  name          String
  email         String?
  keyPrefix     String          @unique
  keyHash       String          @unique
  feeBps        Int             @default(0)
  payoutAddress String?         // EVM address — commissions are settled in USDC (on Base)
  webhookUrl    String?
  webhookSecret String?         // HMAC-SHA256 signing secret for webhook payloads
  active        Boolean         @default(true)
  swapCount     Int             @default(0)
  createdAt     DateTime        @default(now())
  // Email verification for SELF-SERVE registration (anti-abuse). Defaults true so
  // existing rows + operator-minted partners are never retroactively locked out —
  // only /v1/partner/register sets it false (and only when a mailer actually sent
  // the link; if no SMTP is configured it stays true, so registration never breaks).
  emailVerified       Boolean   @default(true)
  verifyTokenHash     String?   // sha256 of the emailed verification token
  verifyTokenExpiresAt DateTime?
  swaps         SwapQuote[]
  payouts       PartnerPayout[]
}

// A settlement run: pays a partner the sum of their unpaid earnings in USDC on Base.
model PartnerPayout {
  id           String     @id @default(uuid())
  partnerId    String
  partner      ApiPartner @relation(fields: [partnerId], references: [id])
  amountUsd    Float
  swapCount    Int
  toAddress    String
  txHash       String?
  status       String     @default("pending") // pending | sent | failed
  createdAt    DateTime   @default(now())
}

model SwapExecutionEvent {
  id        String    @id @default(uuid())
  quoteId   String
  quote     SwapQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  state     String
  status    String
  message   String
  createdAt DateTime  @default(now())

  @@index([quoteId, createdAt])
}

model ComplianceReview {
  id                String     @id @default(uuid())
  subjectType       String
  subjectId         String
  swapQuoteId       String?
  swapQuote         SwapQuote? @relation(fields: [swapQuoteId], references: [id], onDelete: Cascade)
  status            String
  riskScore         Int
  riskTier          String
  walletAddress     String?
  assetContext      String?
  checks            String
  flags             String
  vendorMode        String     @default("simulation")
  vendorProvider    String     @default("atomic-simulated-kyt")
  vendorReferenceId String?
  vendorDecision    String?
  vendorLatencyMs   Int        @default(0)
  vendorMetadata    String     @default("{}")
  decisionNotes     String?
  reviewedBy        String?
  reviewedAt        DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([status, riskTier])
  @@index([subjectType, subjectId])
  @@index([swapQuoteId])
}

model OperatorAuditLog {
  id           String   @id @default(uuid())
  action       String
  subjectType  String
  subjectId    String?
  operatorRole String
  requestId    String?
  method       String
  path         String
  outcome      String
  metadata     String   @default("{}")
  createdAt    DateTime @default(now())

  @@index([action, createdAt])
  @@index([subjectType, subjectId])
  @@index([operatorRole, createdAt])
}

model BugReport {
  id          String   @id @default(uuid())
  reference   String   @unique
  category    String   @default("bug")
  title       String
  description String
  pageUrl     String?
  contact     String?
  userAgent   String?
  severity    String   @default("unset")
  status      String   @default("open")
  source      String   @default("web")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
  @@index([category, createdAt])
}

// Cross-device lookup for the passkey (email) wallet. Stores only the WebAuthn
// credential id (an identifier, NOT a secret) + the derived EOA address, so a
// user can access the same wallet from any device. The private key is never
// stored anywhere — it is re-derived on-device from the passkey via WebAuthn PRF.
model PasskeyCredential {
  id           String   @id @default(uuid())
  email        String   @unique
  credentialId String
  address      String
  chainMode    String   @default("testnet")
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @updatedAt

  @@index([address])
}
