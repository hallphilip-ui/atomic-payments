{
  "key": "",
  "manifest_version": 3,
  "name": "Atomic Pay — Swap & Wallet",
  "version": "0.1.0",
  "description": "One-click cross-chain swaps + your email/Face ID wallet, on any site. Non-custodial, no seed phrase.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Atomic Pay",
    "default_icon": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
  },
  "background": { "service_worker": "src/background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    { "resources": ["src/inpage.js"], "matches": ["<all_urls>"] }
  ],
  "permissions": ["storage"],
  "host_permissions": ["https://atomicpay.cloud/*"],
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
}
