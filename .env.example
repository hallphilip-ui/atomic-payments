NODE_ENV=development
PORT=3005
DATABASE_URL="file:./dev.db"

# simulation | live_with_fallback | live
ATOMIC_SWAP_PROVIDER_MODE=simulation

# --- Live swap routing providers (only needed once ATOMIC_SWAP_PROVIDER_MODE
# leaves simulation). Endpoints default to the documented public URLs. ---
# Rango Basic API key (query param, kept out of returned quote payloads).
ATOMIC_RANGO_API_KEY=
# Optional Rango affiliate/referrer code paired with the 0.5% referrerFee.
ATOMIC_RANGO_REFERRER_CODE=
# Override the Rango quote endpoint if using a dedicated/base URL.
ATOMIC_RANGO_QUOTE_ENDPOINT=
# THORNode quote endpoint (self-hosted or a hosted provider).
ATOMIC_THOR_QUOTE_ENDPOINT=
# x-client-id header most THORNodes (e.g. Nine Realms) expect for identification.
ATOMIC_THOR_CLIENT_ID=

# simulation | live_with_fallback | live
ATOMIC_COMPLIANCE_PROVIDER_MODE=simulation

# Set to production for strict deploy readiness checks.
ATOMIC_DEPLOY_ENV=local

# Required before production webhook use. Never commit real secrets.
ATOMIC_WEBHOOK_SECRET=

# Required before production operator/admin use. Never commit real secrets.
ATOMIC_OPERATOR_API_KEY=

# Arb desk (/arb-desk, and the Flash Lab nested under it) — Cloudflare Access gate.
# Set both to enable per-person browser sign-in instead of the shared operator key.
ARB_ACCESS_TEAM_DOMAIN=
ARB_ACCESS_AUD=

# Who may CHANGE arb-desk settings when signed in via Cloudflare Access — comma-separated,
# case-insensitive. NOT a secret (plain emails).
#
# The Access allow-list decides who can SEE the desk; this decides who can change it.
# Keep them distinct: desk writes retune a live scanner and can repoint the alert topic.
#
# FAILS CLOSED — leaving this empty grants admin to NOBODY via Access (the operator admin
# key above still works, so you cannot lock yourself out). If browser admin is unexpectedly
# refused with a 403, this is almost certainly why; the app logs a warning naming it at
# startup. The value must match the email Cloudflare Access asserts, which the desk shows
# as the signed-in "viewer" — a Google alias will not match the address you type.
ARB_DESK_ADMIN_EMAILS=
