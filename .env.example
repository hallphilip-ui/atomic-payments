NODE_ENV=development
PORT=3005
DATABASE_URL="file:./dev.db"

# simulation | live_with_fallback | live
ATOMIC_SWAP_PROVIDER_MODE=simulation

# simulation | live_with_fallback | live
ATOMIC_COMPLIANCE_PROVIDER_MODE=simulation

# Set to production for strict deploy readiness checks.
ATOMIC_DEPLOY_ENV=local

# Required before production webhook use. Never commit real secrets.
ATOMIC_WEBHOOK_SECRET=

# Required before production operator/admin use. Never commit real secrets.
ATOMIC_OPERATOR_API_KEY=
